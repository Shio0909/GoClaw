# GoClaw 环境变量配置
# 复制此文件为 .env 并填入你的 key
# 切换 GOCLAW_PROVIDER 即可切换提供方: claude / mimo / openai

# === 当前使用的提供方 ===
GOCLAW_PROVIDER=claude
GOCLAW_MODEL=claude-sonnet-4-6

# === Claude ===
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# === 小米 MiMo ===
# MIMO_API_KEY=your-mimo-api-key
# 切换时: GOCLAW_PROVIDER=mimo, GOCLAW_MODEL=MiMo-V2-Pro

# === OpenAI 兼容 (DeepSeek/豆包/Ollama) ===
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# 切换时: GOCLAW_PROVIDER=openai, GOCLAW_MODEL=deepseek-chat

# === 文件操作沙箱 ===
# GOCLAW_SANDBOX=/path/to/sandbox

# === 工具 API Keys ===
# TAVILY_API_KEY=your-tavily-key

# === QQ 机器人 (可选) ===
# GOCLAW_QQ_WS=ws://127.0.0.1:3001
# GOCLAW_QQ_SELF_ID=your-bot-qq-number
# GOCLAW_QQ_ADMINS=admin-qq-number
# GOCLAW_STICKERS_DIR=stickers

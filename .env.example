# GoClaw 环境变量配置
# 复制此文件为 .env 并填入你的 key

# === LLM Provider (二选一) ===

# Claude 模式
GOCLAW_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOCLAW_MODEL=claude-sonnet-4-6

# OpenAI 兼容模式 (DeepSeek/豆包/Ollama 等)
# GOCLAW_PROVIDER=openai
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# GOCLAW_MODEL=deepseek-chat

# === 文件操作沙箱 ===
# GOCLAW_SANDBOX=/path/to/sandbox

# === 工具 API Keys ===
# TAVILY_API_KEY=your-tavily-key

# === QQ 机器人 (可选) ===
# GOCLAW_QQ_WS=ws://127.0.0.1:3001
# GOCLAW_QQ_SELF_ID=your-bot-qq-number
# GOCLAW_QQ_ADMINS=admin-qq-number
